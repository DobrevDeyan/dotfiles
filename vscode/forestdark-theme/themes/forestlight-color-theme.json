    "settings.headerForeground": "#0a0a0a",
    "settings.modifiedItemIndicator": "#0b5f40",
    "settings.checkboxBackground": "#E6EDE8",
    "settings.checkboxBorder": "#A3B5AB",
    "settings.dropdownBackground": "#E6EDE8",
    "settings.dropdownBorder": "#A3B5AB",
    "settings.numberInputBackground": "#E6EDE8",
    "settings.textInputBackground": "#E6EDE8"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#617468", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#0e7f56" }
    },
    {
      "scope": ["string.escape", "constant.character.escape"],
      "settings": { "foreground": "#052b1d" }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.as",
        "keyword.operator.new",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.instanceof",
        "keyword.operator.in",
        "keyword.operator.of",
        "keyword.operator.delete"
      ],
      "settings": { "foreground": "#0b5f40", "fontStyle": "bold" }
    },
    {
      "scope": [
        "storage.type",
        "storage.type.function",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.type",
        "storage.type.enum",
        "storage.modifier",
        "storage.modifier.async",
        "storage.modifier.export",
        "storage.modifier.static",
        "storage.modifier.readonly"
      ],
      "settings": { "foreground": "#0b5f40", "fontStyle": "bold" }
    },
    {
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.trycatch",
        "keyword.control.switch"
      ],
      "settings": { "foreground": "#0b5f40", "fontStyle": "bold" }
    },
    {
      "scope": [
        "keyword.control.exception",
        "keyword.control.throw"
      ],
      "settings": { "foreground": "#CC2200", "fontStyle": "bold" }
    },
    {
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.infinity",
        "constant.language.nan"
      ],
      "settings": { "foreground": "#CC2200", "fontStyle": "bold" }
    },
    {
      "scope": ["constant.numeric", "constant.other.numeric"],
      "settings": { "foreground": "#375753" }
    },
    {
      "scope": ["constant.language", "constant.other"],
      "settings": { "foreground": "#375753" }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.type.alias",
        "support.type",
        "support.class",
        "support.type.primitive"
      ],
      "settings": { "foreground": "#29413e" }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": { "foreground": "#0a0a0a" }
    },
    {
      "scope": [
        "entity.name.function.call",
        "support.function",
        "support.function.builtin",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#0e7f56" }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.constant",
        "meta.definition.variable"
      ],
      "settings": { "foreground": "#0a0a0a" }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": { "foreground": "#0a0a0a" }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameters variable"
      ],
      "settings": { "foreground": "#375753" }
    },
    {
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": { "foreground": "#0b5f40", "fontStyle": "italic" }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "meta.object.member",
        "support.variable.property",
        "variable.other.member"
      ],
      "settings": { "foreground": "#456d68" }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.bitwise",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.optional"
      ],
      "settings": { "foreground": "#A3B5AB" }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.arguments"
      ],
      "settings": { "foreground": "#A3B5AB" }
    },
    {
      "scope": ["meta.type.annotation", "meta.type.parameters"],
      "settings": { "foreground": "#29413e" }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": { "foreground": "#0b5f40" }
    },
    {
      "scope": ["entity.other.attribute-name.html"],
      "settings": { "foreground": "#456d68" }
    },
    {
      "scope": ["entity.name.module", "entity.name.namespace"],
      "settings": { "foreground": "#29413e" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#052b1d", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#0e7f56" }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#375753", "fontStyle": "underline" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#CC2200" }
    }
  ]
}
