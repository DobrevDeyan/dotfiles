  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#536359", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#55ebb4" }
    },
    {
      "scope": ["string.escape", "constant.character.escape"],
      "settings": { "foreground": "#95f2d0" }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.as",
        "keyword.operator.new",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.instanceof",
        "keyword.operator.in",
        "keyword.operator.of",
        "keyword.operator.delete"
      ],
      "settings": { "foreground": "#1adf96", "fontStyle": "bold" }
    },
    {
      "scope": [
        "storage.type",
        "storage.type.function",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.type",
        "storage.type.enum",
        "storage.modifier",
        "storage.modifier.async",
        "storage.modifier.export",
        "storage.modifier.static",
        "storage.modifier.readonly"
      ],
      "settings": { "foreground": "#1adf96", "fontStyle": "bold" }
    },
    {
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.trycatch",
        "keyword.control.switch"
      ],
      "settings": { "foreground": "#1adf96", "fontStyle": "bold" }
    },
    {
      "scope": [
        "keyword.control.exception",
        "keyword.control.throw"
      ],
      "settings": { "foreground": "#FF5733", "fontStyle": "bold" }
    },
    {
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.infinity",
        "constant.language.nan"
      ],
      "settings": { "foreground": "#FF5733", "fontStyle": "bold" }
    },
    {
      "scope": ["constant.numeric", "constant.other.numeric"],
      "settings": { "foreground": "#b7d1ce" }
    },
    {
      "scope": ["constant.language", "constant.other"],
      "settings": { "foreground": "#b7d1ce" }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.type.alias",
        "support.type",
        "support.class",
        "support.type.primitive"
      ],
      "settings": { "foreground": "#568782" }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "scope": [
        "entity.name.function.call",
        "support.function",
        "support.function.builtin",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#75efc2" }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.constant",
        "meta.definition.variable"
      ],
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameters variable"
      ],
      "settings": { "foreground": "#b7d1ce" }
    },
    {
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": { "foreground": "#1adf96", "fontStyle": "italic" }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "meta.object.member",
        "support.variable.property",
        "variable.other.member"
      ],
      "settings": { "foreground": "#8bb5b1" }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.bitwise",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.optional"
      ],
      "settings": { "foreground": "#595959" }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.arguments"
      ],
      "settings": { "foreground": "#595959" }
    },
    {
      "scope": ["meta.type.annotation", "meta.type.parameters"],
      "settings": { "foreground": "#568782" }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": { "foreground": "#1adf96" }
    },
    {
      "scope": ["entity.other.attribute-name.html"],
      "settings": { "foreground": "#8bb5b1" }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "scope": ["entity.name.module", "entity.name.namespace"],
      "settings": { "foreground": "#53827d" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#95f2d0", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#55ebb4" }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#8bb5b1", "fontStyle": "underline" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#FF5733" }
    }
  ]
}
